# Server Port
PORT=5000

# MongoDB Connection
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/jobfinder

# JWT Secret (Generate a strong random string for production)
JWT_SECRET=your_jwt_secret_key_here_generate_a_long_random_string

# Client URL (Frontend URL)
CLIENT_URL=http://localhost:3000

# Node Environment
NODE_ENV=development
